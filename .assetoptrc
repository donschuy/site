{
  "images": {
    "outputFormat": "keep",
    "quality": {
      "jpeg": 85,
      "png": 80,
      "webp": 82,
      "avif": 75
    },
    "stripMetadata": true
  },
  "css": {
    "minify": true
  },
  "js": {
    "minify": true
  },
  "svg": {
    "multipass": true,
    "minifyIds": false
  },
  "output": {
    "dir": "./public"
  }
}
